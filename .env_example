# ==============================================================================
# KGP Insight: Environment Configuration Example
# Copy this file to '.env' and fill in your actual credentials.
# ==============================================================================

# 1. Google Gemini API (LLM & Embeddings)
# Get a free key from: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# 2. Qdrant Cloud (Vector Database)
# Create a free cluster at: https://cloud.qdrant.io/
QDRANT_URL=https://your-qdrant-cluster-url.aws.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here

# 3. Upstash Redis (Semantic Caching)
# Create a free serverless Redis DB at: https://upstash.com/
UPSTASH_REDIS_URL=rediss://default:your_token@your-redis-endpoint.upstash.io:6379
UPSTASH_REDIS_TOKEN=your_upstash_redis_token_here

# 4. Neon PostgreSQL (Relational Analytics Logs)
# Create a free serverless Postgres DB at: https://neon.tech/
NEON_DATABASE_URL=postgresql://user:password@your-neon-host.neon.tech/neondb?sslmode=require

# 5. IIT Kharagpur ERP Credentials (Optional - Phase 1)
# Used by Playwright to scrape notices dynamically
ERP_ROLL_NO=
ERP_PASSWORD=
